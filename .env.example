# Copy to .env and fill in your keys (do not commit .env).
# Minimal setup: set STRIPE_API_KEY + one of OPENAI_API_KEY or ANTHROPIC_API_KEY to run paid jobs with built-in workers.

# --- Required for paid demo ---
STRIPE_API_KEY=sk_test_xxxxxxxx
# At least one LLM key (for CEO, audit, and built-in workers: summarize / research / reply)
OPENAI_API_KEY=sk-xxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Optional: prefer Anthropic when both are set
# SOVEREIGN_LLM_PROVIDER=anthropic
# SOVEREIGN_LLM_MODEL=claude-3-5-sonnet-20241022

# --- Optional: persistence ---
SOVEREIGN_JOB_DB=./data/jobs.db
SOVEREIGN_LEDGER_PATH=./data/ledger.jsonl
SOVEREIGN_AUDIT_TRAIL_PATH=./data/audit.jsonl

# --- Optional: job completion webhook (Phase C) ---
# SOVEREIGN_WEBHOOK_URL=https://your-server.com/webhook
# SOVEREIGN_WEBHOOK_SECRET=your-secret-for-hmac
