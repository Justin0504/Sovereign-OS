# Copy to .env and fill in your keys (do not commit .env).
# Minimal setup: set STRIPE_API_KEY + one of OPENAI_API_KEY or ANTHROPIC_API_KEY to run paid jobs with built-in workers.

# --- Payment provider selection ---
# PAYMENT_PROVIDER chooses the settlement rail: "x402" | "stripe" | "dummy".
# If unset, x402 is auto-selected when X402_PAY_TO is set; else Stripe if STRIPE_API_KEY is set; else Dummy.
# PAYMENT_PROVIDER=x402

# --- x402 / USDC rail (agentic payments; defaults to SANDBOX/testnet — never moves real funds) ---
# X402_PAY_TO=0xYourPayoutAddress
# X402_NETWORK=base-sepolia        # testnet by default; set to "base" for mainnet
# X402_ASSET=USDC
# X402_SANDBOX=true                # set false + X402_FACILITATOR_URL to settle for real
# X402_FACILITATOR_URL=https://facilitator.example.com
# X402_API_KEY=optional-bearer-token

# --- Required for Stripe paid demo ---
STRIPE_API_KEY=sk_test_xxxxxxxx
# At least one LLM key (for CEO, audit, and built-in workers: summarize / research / reply)
OPENAI_API_KEY=sk-xxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Optional: prefer Anthropic when both are set
# SOVEREIGN_LLM_PROVIDER=anthropic
# SOVEREIGN_LLM_MODEL=claude-3-5-sonnet-20241022

# --- Optional: persistence ---
SOVEREIGN_JOB_DB=./data/jobs.db
SOVEREIGN_LEDGER_PATH=./data/ledger.jsonl
SOVEREIGN_AUDIT_TRAIL_PATH=./data/audit.jsonl

# --- Optional: control API cost (avoid jobs running / 接单 non-stop) ---
# Leave SOVEREIGN_AUTO_APPROVE_JOBS unset so new jobs need manual Approve in Dashboard.
# Unset SOVEREIGN_INGEST_URL (or set SOVEREIGN_INGEST_ENABLED=false) to stop automatic intake.
# Set SOVEREIGN_JOB_WORKER_ENABLED=false to pause all execution (no jobs run until true + restart).
# For demo: pull from local JSON once, only a few jobs per start:
# 1) Start demo orders server:  python scripts/serve_demo_orders.py
# 2) Set:
# SOVEREIGN_INGEST_URL=http://localhost:8765/jobs?limit=3
# SOVEREIGN_INGEST_ONCE=true
# SOVEREIGN_AUTO_APPROVE_JOBS=true
# SOVEREIGN_INGEST_URL=http://localhost:9000/jobs?take=true
# SOVEREIGN_INGEST_ENABLED=false
# SOVEREIGN_JOB_WORKER_ENABLED=false

# --- Optional: per-model token pricing override (cost tracing) ---
# JSON map of model_id -> [usd_per_1M_input, usd_per_1M_output]. Extends/overrides the
# built-in table in sovereign_os/governance/pricing.py.
# SOVEREIGN_MODEL_PRICING_JSON={"my-model":[1.0,3.0],"gpt-4o":[2.5,10.0]}

# --- Optional: ClawTasks bounty marketplace (auto-accept loop) ---
# Discovery (GET /bounties) needs no auth and moves no funds — safe to enable.
# BRIDGE_CLAWTASKS_ENABLED=true
# CLAWTASKS_BASE_URL=https://clawtasks.com/api
# CLAWTASKS_MIN_AMOUNT_USD=1
# CLAWTASKS_MAX_AMOUNT_USD=0          # 0 = no max
# CLAWTASKS_TAGS=writing,research     # empty = any
# CLAWTASKS_REQUIRE_FUNDED=true
# Claim/submit back to ClawTasks STAKES real USDC on Base — DRY-RUN unless live:
# CLAWTASKS_API_KEY=your-bearer-token
# CLAWTASKS_LIVE=false                # set true ONLY with a funded Base wallet

# --- Optional: TaskBounty marketplace (live; auto-ingest open bounties) ---
# Discovery (GET /api/v1/tasks) needs no auth and moves no funds — safe to enable.
# BRIDGE_TASKBOUNTY_ENABLED=true
# TASKBOUNTY_API_BASE=https://www.task-bounty.com/api/v1
# TASKBOUNTY_LIST_PATH=/tasks
# TASKBOUNTY_MIN_AMOUNT_USD=0        # 0 = no floor
# TASKBOUNTY_MAX_AMOUNT_USD=0        # 0 = no max
# TASKBOUNTY_API_KEY=tb_live_xxx     # only needed for claim/submit-back (not for discovery)

# --- Optional: StacksTasker marketplace (live; STX on Stacks testnet) ---
# BRIDGE_STACKSTASKER_ENABLED=true
# STACKSTASKER_API_BASE=https://stackstasker.com
# STACKSTASKER_MIN_AMOUNT=0         # in STX units; 0 = no floor

# --- Optional: BotBounty marketplace (live; Base L2, USDC/ETH) ---
# Discovery needs no auth. Note the API base is the Railway host, not the .ai domain.
# BRIDGE_BOTBOUNTY_ENABLED=true
# BOTBOUNTY_API_BASE=https://botbounty-production.up.railway.app/api
# BOTBOUNTY_MIN_AMOUNT_USD=0

# --- Optional: outbound oversight — RentAHuman (agent posts, human works) ---
# Posting/funding/releasing escrow moves real money — DRY-RUN unless live.
# RENTAHUMAN_API_KEY=rah_live_xxx
# RENTAHUMAN_LIVE=false            # set true ONLY with a funded account; gate behind your own confirm
# SOVEREIGN_OVERSIGHT_DB=./data/oversight.json   # persist posted escrows (web panel + CLI)
# Before going live: python -m sovereign_os.oversight.rentahuman_preflight  (GO/NO-GO, moves no funds)

# --- Optional: StacksTasker outbound (budget-gated posting; STX testnet, no real funds) ---
# STACKSTASKER_POSTER_ADDRESS=ST...   # your Stacks wallet (required only for live posting)
# See docs/OVERSIGHT.md.

# --- Optional: job completion webhook (Phase C) ---
# SOVEREIGN_WEBHOOK_URL=https://your-server.com/webhook
# SOVEREIGN_WEBHOOK_SECRET=your-secret-for-hmac

# --- Optional: Figma connector (read design files for the design category) ---
# Figma REST API is read-only — agents read a file's structure to implement/audit it,
# they cannot create designs via REST. Get a token at figma.com (Settings > Personal access tokens).
# FIGMA_TOKEN=figd_xxx

# --- Optional: auto-enable the worker tool loop by category ---
# When true, research/data/coding/design tasks run the agentic tool loop (web_fetch,
# read repo, run tests, submit PR, read Figma, generate images) instead of single-shot.
# SOVEREIGN_AUTO_TOOLS=false
# SOVEREIGN_WORKSPACE_ROOT=/path/to/checkout   # injected for coding tasks

# --- Optional: sandbox untrusted code execution (run_tests) in Docker ---
# SOVEREIGN_CODE_SANDBOX=docker         # run repo tests in a container (requires docker)
# SOVEREIGN_SANDBOX_IMAGE=python:3.12-slim
# SOVEREIGN_SANDBOX_NETWORK=none        # none (default) or bridge

# --- Optional: TaskBounty PR delivery-back (submit the fix's PR to the bounty) ---
# Submits a paid deliverable -> DRY-RUN unless live. Exact submit path isn't public; override if needed.
# TASKBOUNTY_LIVE=false
# TASKBOUNTY_SUBMIT_PATH=/tasks/{id}/submit

# --- Optional: StacksTasker bid+submit delivery-back (STX testnet) ---
# Bidding stakes STX -> DRY-RUN unless live. Submit path isn't public; override if needed.
# STACKSTASKER_LIVE=false
# STACKSTASKER_AGENT_ID=your-registered-agent-id
# STACKSTASKER_SUBMIT_PATH=/tasks/{id}/submit
